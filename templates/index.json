            "liquid": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Checkmarks – Serenilyfe</title>\n    <style>\n        .checkmark-list {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n            margin-bottom: -5px !important;\n        }\n        .checkmark-item {\n            display: flex;\n            align-items: center;\n            margin-bottom: 10px;\n            font-size: 15px;\n            font-weight: 600;\n            color: #141414;\n            line-height: 1.5;\n        }\n        .checkmark-item::before {\n            content: \"✔\";\n            color: #8A4B2D;\n            font-weight: 700;\n            font-size: 16px;\n            margin-right: 10px;\n        }\n    </style>\n</head>\n<body>\n    <ul class=\"checkmark-list\">\n        <li class=\"checkmark-item\">Formule 100% détaillée : romarin, kératine hydrolysée & biotine</li>\n        <li class=\"checkmark-item\">Cuir chevelu visiblement apaisé dès les premiers lavages</li>\n        <li class=\"checkmark-item\">Nettoyant aux acides aminés, sans sulfates ni parabènes</li>\n        <li class=\"checkmark-item\">Une seule routine : 2 à 3 minutes de massage sous la douche</li>\n    </ul>\n</body>\n</html>"
